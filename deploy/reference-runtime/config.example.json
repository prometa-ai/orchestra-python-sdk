{
  "configVersion": 1,
  "tenantId": "tenant-runtime-owner",
  "runtimeId": "runtime-prod-01",
  "runtimeVersion": "0.18.3",
  "orgId": "org-from-signed-release",
  "environment": "prod",
  "releaseId": "release-from-promotion-attestation",
  "deploymentId": "deployment-from-promotion-attestation",
  "runtimeTarget": "tenant-runtime",
  "bundle": {},
  "promotionAttestation": {},
  "bundleTrust": [
    {
      "issuer": "https://orchestra.example/",
      "keyId": "bundle-signing-key-id",
      "publicKeySpkiDerBase64": "tenant-provisioned-public-key",
      "allowedOrgIds": ["org-from-signed-release"],
      "allowedAudiences": ["prometa-runtime"],
      "allowedEnvironments": ["prod"]
    }
  ],
  "promotionTrust": [
    {
      "issuer": "https://orchestra.example/promotion",
      "keyId": "promotion-signing-key-id",
      "publicKeySpkiDerBase64": "tenant-provisioned-public-key",
      "allowedOrgIds": ["org-from-signed-release"],
      "allowedAudiences": ["prometa-runtime-admission"],
      "allowedEnvironments": ["prod"]
    }
  ],
  "modelGateway": {
    "baseUrl": "http://tenant-model-gateway:8000",
    "apiKeyEnv": "MODEL_GATEWAY_API_KEY",
    "endpointPath": "/v1/chat/completions",
    "timeoutSeconds": 30,
    "maxResponseBytes": 4194304
  },
  "databaseDsnEnv": "PROMETA_RUNTIME_DATABASE_URL",
  "apiTokenEnv": "PROMETA_RUNTIME_API_TOKEN",
  "requestTimeoutSeconds": 60,
  "maxRequestBytes": 1048576,
  "taskRecovery": {
    "leaseSeconds": 90,
    "maxAttempts": 3,
    "historyLimit": 50
  }
}
